release/minesweeper.app/Contents/PkgInfo: 
	@test -d release/minesweeper.app/Contents || mkdir -p release/minesweeper.app/Contents
	@$(DEL_FILE) release/minesweeper.app/Contents/PkgInfo
	@echo "APPL????" > release/minesweeper.app/Contents/PkgInfo
release/minesweeper.app/Contents/Resources/empty.lproj: 
	@test -d release/minesweeper.app/Contents/Resources || mkdir -p release/minesweeper.app/Contents/Resources
	@touch release/minesweeper.app/Contents/Resources/empty.lproj
	
release/minesweeper.app/Contents/Info.plist: 
	@test -d release/minesweeper.app/Contents || mkdir -p release/minesweeper.app/Contents
	@$(DEL_FILE) release/minesweeper.app/Contents/Info.plist
	@sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,com.yourcompany.minesweeper,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},com.yourcompany.minesweeper,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},10.13,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,minesweeper,g" -e "s,@LIBRARY@,minesweeper,g" -e "s,\$${EXECUTABLE_NAME},minesweeper,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" /usr/local/Cellar/qt@5/5.15.17/mkspecs/macx-clang/Info.plist.app >release/minesweeper.app/Contents/Info.plist

all: Makefile \
